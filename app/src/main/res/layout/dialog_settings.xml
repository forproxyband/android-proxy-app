<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share connection (host / port / key / dns only):"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">
        <Button
            android:id="@+id/btnImport"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:text="IMPORT CONNECTION"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />
        <Button
            android:id="@+id/btnExport"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:text="EXPORT CONNECTION"
            android:textSize="11sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <EditText
        android:id="@+id/etHost"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Host"
        android:inputType="text"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etPort"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Port"
        android:inputType="number"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etKey"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Agent Key"
        android:inputType="text"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDns"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="DNS servers (empty = 1.1.1.1,8.8.8.8)"
        android:inputType="text"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <CheckBox
        android:id="@+id/cbSpeedBytes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show speed in MB/s (bytes) instead of Mb/s (bits)"
        android:textSize="12sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="10dp"
        android:background="#33888888" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Engine:"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/rgEngine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <RadioButton
            android:id="@+id/rbEngineBinary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Binary subprocess (default)"
            android:textSize="13sp" />
        <RadioButton
            android:id="@+id/rbEngineAar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="In-process AAR (gomobile)"
            android:textSize="13sp" />
    </RadioGroup>

</LinearLayout>
